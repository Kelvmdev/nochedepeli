---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PeliculaCard from "../../components/PeliculaCard.astro";
import { porFecha } from "../../lib/catalogo";

const animes = (await getCollection("catalogo"))
  .filter((p) => p.data.tipo === "anime")
  .sort(porFecha);
---
<Layout
  title="Todo el anime — nochedepeli"
  description="Reseñas de anime y dónde verlo legal en Colombia."
>
  <section class="max-w-7xl mx-auto px-[5%] py-12">
    <h1 class="font-display text-3xl md:text-4xl font-extrabold mb-2">Todo el anime</h1>
    <p class="text-tenue mb-8">{animes.length} reseña{animes.length === 1 ? "" : "s"} · dónde verlo legal en Colombia.</p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      {animes.map((p) => <PeliculaCard p={p} />)}
    </div>

    {animes.length === 0 && <p class="text-tenue text-center py-16">Aún no hay anime. ¡Pronto!</p>}
  </section>
</Layout>
