---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PeliculaCard from "../../components/PeliculaCard.astro";
import { porFecha } from "../../lib/catalogo";

const pelis = (await getCollection("catalogo"))
  .filter((p) => p.data.tipo === "pelicula")
  .sort(porFecha);
---
<Layout
  title="Todas las películas — nochedepeli"
  description="Todas nuestras reseñas de películas y dónde verlas legal en Colombia."
>
  <section class="max-w-7xl mx-auto px-[5%] py-12">
    <h1 class="font-display text-3xl md:text-4xl font-extrabold mb-2">Todas las películas</h1>
    <p class="text-tenue mb-8">{pelis.length} reseña{pelis.length === 1 ? "" : "s"} · dónde verlas legal en Colombia.</p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      {pelis.map((p) => <PeliculaCard p={p} />)}
    </div>

    {pelis.length === 0 && <p class="text-tenue text-center py-16">Aún no hay películas. ¡Pronto!</p>}
  </section>
</Layout>
