---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PeliculaCard from "../../components/PeliculaCard.astro";
import { porFecha } from "../../lib/catalogo";

// Un solo molde para /peliculas, /series y /anime (antes eran 3 archivos iguales).
// Cada sección solo cambia el tipo y los textos.
const SECCIONES = {
  peliculas: {
    tipo: "pelicula",
    title: "Todas las películas — nochedepeli",
    desc: "Todas nuestras reseñas de películas y dónde verlas legal en Colombia.",
    h1: "Todas las películas",
    sub: "· dónde verlas legal en Colombia.",
    vacio: "Aún no hay películas. ¡Pronto!",
  },
  series: {
    tipo: "serie",
    title: "Todas las series — nochedepeli",
    desc: "Reseñas de series por temporadas y dónde verlas legal en Colombia.",
    h1: "Todas las series",
    sub: "· por temporadas, dónde verlas legal.",
    vacio: "Aún no hay series. ¡Pronto!",
  },
  anime: {
    tipo: "anime",
    title: "Todo el anime — nochedepeli",
    desc: "Reseñas de anime y dónde verlo legal en Colombia.",
    h1: "Todo el anime",
    sub: "· dónde verlo legal en Colombia.",
    vacio: "Aún no hay anime. ¡Pronto!",
  },
} as const;

export function getStaticPaths() {
  // Nota: getStaticPaths corre aislado, no ve SECCIONES de arriba → claves literales.
  return ["peliculas", "series", "anime"].map((seccion) => ({ params: { seccion } }));
}

const cfg = SECCIONES[Astro.params.seccion as keyof typeof SECCIONES];
const items = (await getCollection("catalogo"))
  .filter((p) => p.data.tipo === cfg.tipo)
  .sort(porFecha);
---
<Layout title={cfg.title} description={cfg.desc}>
  <section class="max-w-7xl mx-auto px-[5%] py-12">
    <h1 class="font-display text-3xl md:text-4xl font-extrabold mb-2">{cfg.h1}</h1>
    <p class="text-tenue mb-8">{items.length} reseña{items.length === 1 ? "" : "s"} {cfg.sub}</p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      {items.map((p) => <PeliculaCard p={p} />)}
    </div>

    {items.length === 0 && <p class="text-tenue text-center py-16">{cfg.vacio}</p>}
  </section>
</Layout>
