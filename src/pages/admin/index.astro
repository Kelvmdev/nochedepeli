---
export const prerender = false;
import "../../styles/global.css";
import { getCollection } from "astro:content";
import { sesionValida, NOMBRE_COOKIE } from "../../lib/auth";
import { site } from "../../lib/site";
import { porFecha } from "../../lib/catalogo";
import FormResena from "../../components/FormResena.astro";

const autenticado = sesionValida(Astro.cookies.get(NOMBRE_COOKIE)?.value);
const error = Astro.url.searchParams.get("error");
const err = Astro.url.searchParams.get("err");
const ok = Astro.url.searchParams.get("ok");

const input = "w-full bg-noche border border-linea rounded-lg px-3 py-2.5 outline-none focus:border-ambar";
const label = "block text-sm font-medium mb-1.5";

const reseñas = autenticado ? (await getCollection("catalogo")).sort(porFecha) : [];
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Panel — nochedepeli</title>
  </head>
  <body class="min-h-screen bg-noche text-hueso">
    {!autenticado ? (
      <main class="min-h-screen grid place-items-center px-[5%]">
        <form method="POST" action="/api/login" class="w-full max-w-sm bg-superficie border border-linea rounded-2xl p-8">
          <p class="font-display text-2xl font-extrabold mb-1">noche<span class="text-ambar">de</span>peli</p>
          <p class="text-tenue text-sm mb-6">Panel de administración</p>
          {error && <p class="bg-red-500/15 text-red-300 text-sm rounded-lg px-3 py-2 mb-4">Contraseña incorrecta.</p>}
          <label class={label} for="password">Contraseña</label>
          <input id="password" name="password" type="password" required autocomplete="current-password" class={`${input} mb-5`} />
          <button class="w-full bg-ambar text-noche font-semibold py-2.5 rounded-lg transition active:scale-95 hover:bg-ambardeep">Entrar</button>
        </form>
      </main>
    ) : (
      <main class="max-w-2xl mx-auto px-[5%] py-12">
        <header class="flex items-center justify-between mb-8">
          <p class="font-display text-2xl font-extrabold">noche<span class="text-ambar">de</span>peli · Panel</p>
          <div class="flex items-center gap-3">
            <a href="/" class="text-tenue text-sm hover:text-hueso">Ver sitio ↗</a>
            <form method="POST" action="/api/logout"><button class="text-tenue text-sm hover:text-hueso border border-linea rounded-lg px-3 py-1.5">Salir</button></form>
          </div>
        </header>

        {ok && <p class="bg-green-500/15 text-green-300 text-sm rounded-lg px-4 py-3 mb-6">✅ Listo: <b>{ok}</b>. Vercel republica en ~1 minuto.</p>}
        {err && <p class="bg-red-500/15 text-red-300 text-sm rounded-lg px-4 py-3 mb-6">❌ {err}</p>}

        <h1 class="font-display text-xl font-bold mb-5">Nueva reseña</h1>
        <FormResena />

        <h1 class="font-display text-xl font-bold mt-12 mb-5">Reseñas publicadas ({reseñas.length})</h1>
        <ul class="space-y-2">
          {reseñas.map((r) => (
            <li class="flex items-center gap-3 bg-superficie border border-linea rounded-xl px-4 py-3">
              <span class="text-xs text-tenue uppercase w-14 shrink-0">{r.data.tipo}</span>
              <span class="flex-1 text-sm truncate">{r.data.pelicula}</span>
              <a href={`/admin/editar/${r.id}`} class="text-ambar text-sm hover:underline shrink-0">Editar</a>
              <form method="POST" action="/api/borrar" onsubmit="return confirm('¿Borrar esta reseña? No se puede deshacer.')">
                <input type="hidden" name="slug" value={r.id} />
                <button class="text-red-300 text-sm hover:underline shrink-0">Borrar</button>
              </form>
            </li>
          ))}
        </ul>

        <h1 class="font-display text-xl font-bold mt-12 mb-5">Configuración del sitio</h1>
        <form method="POST" action="/api/config" class="space-y-5 bg-superficie border border-linea rounded-2xl p-6 md:p-8">
          <div>
            <label class={label} for="tagline">Tagline (footer)</label>
            <input id="tagline" name="tagline" value={site.tagline} class={input} />
          </div>
          <div>
            <label class={label} for="email">Correo de contacto</label>
            <input id="email" name="email" type="email" value={site.email} class={input} />
          </div>
          <div class="grid md:grid-cols-3 gap-5">
            <div>
              <label class={label} for="instagram">Instagram (URL)</label>
              <input id="instagram" name="instagram" value={site.instagram} class={input} placeholder="https://instagram.com/..." />
            </div>
            <div>
              <label class={label} for="tiktok">TikTok (URL)</label>
              <input id="tiktok" name="tiktok" value={site.tiktok} class={input} placeholder="https://tiktok.com/@..." />
            </div>
            <div>
              <label class={label} for="youtube">YouTube (URL)</label>
              <input id="youtube" name="youtube" value={site.youtube} class={input} placeholder="https://youtube.com/@..." />
            </div>
          </div>
          <p class="text-tenue text-xs">Las redes vacías no se muestran en el footer.</p>
          <button class="w-full bg-superficie border border-ambar text-ambar font-semibold py-3 rounded-lg transition active:scale-95 hover:bg-ambar hover:text-noche">Guardar configuración</button>
        </form>
      </main>
    )}
  </body>
</html>
