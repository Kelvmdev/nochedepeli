---
import { site } from "../lib/site";

const columnas = [
  { titulo: "Explorar", links: [
    { t: "Películas", h: "/peliculas" },
    { t: "Series", h: "/series" },
    { t: "Anime", h: "/anime" },
  ]},
  { titulo: "Legal", links: [
    { t: "Privacidad", h: "/privacidad" },
    { t: "Aviso de afiliados", h: "/aviso-afiliados" },
    { t: "Contacto", h: `mailto:${site.email}` },
  ]},
];

// Redes: solo las que tengan link configurado
const redes = [
  { t: "Instagram", h: site.instagram },
  { t: "TikTok", h: site.tiktok },
  { t: "YouTube", h: site.youtube },
].filter((r) => r.h);

const anio = new Date().getFullYear();
---
<footer class="border-t border-linea mt-8">
  <div class="max-w-7xl mx-auto px-[5%] py-12 grid grid-cols-2 md:grid-cols-4 gap-8 text-sm">
    <div class="col-span-2 md:col-span-1">
      <p class="font-display text-xl font-extrabold mb-3">noche<span class="text-ambar">de</span>peli</p>
      <p class="text-tenue">{site.tagline}</p>
    </div>
    {columnas.map((c) => (
      <div>
        <p class="font-semibold mb-3">{c.titulo}</p>
        <ul class="space-y-2 text-tenue">
          {c.links.map((l) => <li><a href={l.h} class="hover:text-hueso transition">{l.t}</a></li>)}
        </ul>
      </div>
    ))}
    {redes.length > 0 && (
      <div>
        <p class="font-semibold mb-3">Síguenos</p>
        <ul class="space-y-2 text-tenue">
          {redes.map((r) => <li><a href={r.h} target="_blank" rel="noopener" class="hover:text-hueso transition">{r.t}</a></li>)}
        </ul>
      </div>
    )}
  </div>
  <div class="border-t border-linea py-5 text-center text-xs text-tenue">
    © {anio} nochedepeli · Hecho con ♥ en Medellín
  </div>
</footer>
