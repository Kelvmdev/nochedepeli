# Plantilla de variables de entorno (SIN valores reales).
# Copia a .env.local y rellena. Nunca subas .env.local a GitHub.

# --- Login del panel (Fase 2) ---
SESSION_SECRET=   # llave aleatoria para firmar la sesión (generada)
ADMIN_PASSWORD=   # tu contraseña del panel /admin

# --- Guardado en GitHub (Fase 3) ---
GITHUB_TOKEN=     # token PAT de GitHub (permiso: repo/public_repo). Solo en servidor.
GITHUB_OWNER=Kelvmdev
GITHUB_REPO=nochedepeli
GITHUB_BRANCH=main
